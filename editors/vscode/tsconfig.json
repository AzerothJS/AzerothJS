{
    "compilerOptions":
    {
        "module": "Node16",
        "moduleResolution": "Node16",
        "target": "ES2022",
        "lib":
        [
            "ES2022"
        ],
        "types":
        [
            "node"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "declaration": false
    },
    "include":
    [
        "src/**/*"
    ],
    "exclude":
    [
        "node_modules",
        "dist"
    ]
}
