<idea-plugin>
    <id>com.azerothjs.azeroth</id>
    <name>AzerothJS</name>
    <vendor url="https://github.com/IntelligentQuantum-Dev/AzerothJS">AzerothJS</vendor>
    <description><![CDATA[
        Language support for AzerothJS <code>.azeroth</code> files.
        <ul>
            <li>Native <code>.azeroth</code> language: syntax highlighting and correct bracket
                matching (a real lexer, so braces inside strings, comments, and template
                interpolations never throw off the pairing).</li>
            <li>Compiler-aware intelligence — completion, hover, diagnostics, navigation, rename,
                signature help, formatting, and semantic highlighting — from the AzerothJS
                language server.</li>
        </ul>
        Requires a paid JetBrains IDE (LSP API) and Node.js on PATH.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Native .azeroth language: lexer-driven highlighting + brace matching. -->
        <fileType
            name="AzerothJS"
            implementationClass="com.azerothjs.lang.AzerothFileType"
            fieldName="INSTANCE"
            language="AzerothJS"
            extensions="azeroth"/>
        <lang.parserDefinition
            language="AzerothJS"
            implementationClass="com.azerothjs.lang.AzerothParserDefinition"/>
        <lang.syntaxHighlighterFactory
            language="AzerothJS"
            implementationClass="com.azerothjs.lang.AzerothSyntaxHighlighterFactory"/>
        <lang.braceMatcher
            language="AzerothJS"
            implementationClass="com.azerothjs.lang.AzerothBraceMatcher"/>

        <!-- Compiler-aware intelligence over LSP. -->
        <platform.lsp.serverSupportProvider
            implementation="com.azerothjs.AzerothLspServerSupportProvider"/>
        <typedHandler implementation="com.azerothjs.AzerothTypedHandler"/>
        <applicationConfigurable
            parentId="language"
            id="com.azerothjs.settings"
            displayName="AzerothJS"
            instance="com.azerothjs.AzerothConfigurable"/>
    </extensions>
</idea-plugin>
