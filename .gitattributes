# Default normalization
* text=auto eol=lf

# Mark images as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

# Avoid Git messing with archives
*.zip binary
*.gz  binary
*.tar binary

# --- GitHub language detection (Linguist) ---

# .azeroth single-file components are TypeScript modules with JSX-style markup.
# Linguist has no native .azeroth grammar, so we render them with the closest
# one (TSX) for readable highlighting, but mark them undetectable so they do NOT
# count toward the repo's language statistics - AzerothJS is its own language,
# not a TSX project. (A native "Azeroth" language requires an upstream
# github/linguist submission once the framework clears its popularity bar.)
*.azeroth linguist-language=TSX linguist-detectable=false

# Bundled third-party TextMate grammars (vendored from Microsoft) should not
# count toward the repository's language statistics.
editors/jetbrains/src/main/resources/textmate/TypeScript.tmLanguage.json linguist-vendored
editors/jetbrains/src/main/resources/textmate/TypeScriptReact.tmLanguage.json linguist-vendored
