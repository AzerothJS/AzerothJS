{
    "name": "@azerothjs/renderer",
    "version": "0.3.0-alpha.3",
    "description": "AzerothJS DOM renderer — h(), Show, For, Switch, Portal, Dynamic, classList, styleMap",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@azerothjs/reactivity": "0.3.0-alpha.3",
        "@azerothjs/component": "0.3.0-alpha.3"
    },
    "publishConfig": {
        "access": "public"
    },
    "author": "IntelligentQuantum",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/IntelligentQuantum-Dev/AzerothJS.git",
        "directory": "packages/renderer"
    },
    "homepage": "https://github.com/IntelligentQuantum-Dev/AzerothJS/tree/main/packages/renderer",
    "bugs": {
        "url": "https://github.com/IntelligentQuantum-Dev/AzerothJS/issues"
    }
}
