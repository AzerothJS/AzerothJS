{
    "name": "@azerothjs/renderer",
    "version": "0.5.0-beta.2",
    "description": "AzerothJS DOM renderer — h(), Show, For, Switch, Portal, Dynamic, classList, styleMap",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports":
    {
        ".":
        {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files":
    [
        "dist"
    ],
    "sideEffects": false,
    "scripts":
    {
        "build": "tsc -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "dependencies":
    {
        "@azerothjs/reactivity": "0.5.0-beta.2",
        "@azerothjs/component": "0.5.0-beta.2"
    },
    "publishConfig":
    {
        "access": "public"
    },
    "author":
    {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "repository":
    {
        "type": "git",
        "url": "git+https://github.com/IntelligentQuantum-Dev/AzerothJS.git",
        "directory": "packages/renderer"
    },
    "homepage": "https://github.com/IntelligentQuantum-Dev/AzerothJS/tree/main/packages/renderer",
    "bugs":
    {
        "url": "https://github.com/IntelligentQuantum-Dev/AzerothJS/issues"
    }
