{
    "name": "@azerothjs/language-service",
    "version": "0.9.0-beta.4",
    "description": "AzerothJS language service - compiler-aware intelligence for .azeroth files (completion, hover, definition, diagnostics, ...)",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "dependencies": {
        "@azerothjs/compiler": "0.9.0-beta.4",
        "vscode-css-languageservice": "^6",
        "vscode-html-languageservice": "^5",
        "vscode-languageserver-textdocument": "^1"
    },
    "peerDependencies": {
        "typescript": ">=5 <7"
    },
    "scripts": {
        "build": "node ../../scripts/tsc7.mjs -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "author": {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "engines": {
        "node": ">=24"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/language-service"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS/tree/main/packages/language-service",
    "bugs": {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
