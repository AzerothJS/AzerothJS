{
    "name": "@azerothjs/devtools",
    "version": "0.9.0-beta.2",
    "engines": {
        "node": ">=24"
    },
    "description": "AzerothJS devtools - tabbed in-page panel (tree, dependency graph, timeline, performance) plus an embeddable agent",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "node ../../scripts/tsc7.mjs -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@azerothjs/reactivity": "0.9.0-beta.2"
    },
    "publishConfig": {
        "access": "public"
    },
    "author": {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/devtools"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS/tree/main/packages/devtools",
    "bugs": {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
