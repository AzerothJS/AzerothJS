{
    "name": "azerothjs",
    "version": "0.8.0-beta.2",
    "engines": {
        "node": ">=24"
    },
    "description": "AzerothJS - fine-grained reactive framework with compiled .azeroth components: signals, zero Virtual DOM, direct DOM updates",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "clean": "node ../../scripts/clean.mjs dist",
        "prebuild": "npm run clean",
        "build": "node ../../scripts/tsc7.mjs -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@azerothjs/reactivity": "0.8.0-beta.2",
        "@azerothjs/renderer": "0.8.0-beta.2",
        "@azerothjs/component": "0.8.0-beta.2",
        "@azerothjs/server": "0.8.0-beta.2",
        "@azerothjs/store": "0.8.0-beta.2",
        "@azerothjs/form": "0.8.0-beta.2",
        "@azerothjs/router": "0.8.0-beta.2"
    },
    "keywords": [
        "framework",
        "reactive",
        "signals",
        "fine-grained",
        "no-vdom",
        "dom",
        "typescript",
        "frontend",
        "azeroth"
    ],
    "publishConfig": {
        "access": "public"
    },
    "author": {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/azerothjs"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS#readme",
    "bugs": {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
