{
    "name": "@azerothjs/cron",
    "version": "0.8.0-beta.1",
    "private": true,
    "engines": {
        "node": ">=24"
    },
    "description": "AzerothJS job scheduler - drift-free cron expressions with timezone/DST semantics, overlap control, and graceful drain, zero dependencies",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "clean": "node ../../scripts/clean.mjs dist",
        "prebuild": "npm run clean",
        "build": "node ../../scripts/tsc7.mjs -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "author": {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/cron"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS/tree/main/packages/cron",
    "bugs": {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
