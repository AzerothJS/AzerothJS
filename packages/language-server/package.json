{
    "name": "@azerothjs/language-server",
    "version": "0.7.0-beta.1",
    "description": "AzerothJS language server — a Language Server Protocol front-end for .azeroth files",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin":
    {
        "azeroth-language-server": "./dist/cli.js",
        "azeroth-tsc": "./dist/tsc-cli.js",
        "azeroth-docgen": "./dist/docgen-cli.js"
    },
    "exports":
    {
        ".":
        {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./cli": "./dist/cli.js",
        "./tsc": "./dist/tsc.js",
        "./docgen": "./dist/docgen-cli.js"
    },
    "files":
    [
        "dist"
    ],
    "sideEffects": false,
    "dependencies":
    {
        "@azerothjs/language-service": "0.7.0-beta.1",
        "typescript": ">=6",
        "vscode-languageserver": "^10",
        "vscode-languageserver-textdocument": "^1"
    },
    "scripts":
    {
        "build": "tsc -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "publishConfig":
    {
        "access": "public"
    },
    "author":
    {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "engines": { "node": ">=24" },
    "repository":
    {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/language-server"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS/tree/main/packages/language-server",
    "bugs":
    {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
