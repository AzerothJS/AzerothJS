{
    "name": "create-azeroth",
    "version": "0.9.0-beta.4",
    "engines": {
        "node": ">=24"
    },
    "description": "Scaffold an AzerothJS app - frontend, backend, or fullstack - with the framework's canon wired in: azeroth CLI verbs, eslint rules, typecheck gate, and a working dev loop. Run `npm create azeroth@latest`",
    "type": "module",
    "bin": {
        "create-azeroth": "./dist/cli.js"
    },
    "files": [
        "dist",
        "templates"
    ],
    "sideEffects": false,
    "scripts": {
        "clean": "node ../../scripts/clean.mjs dist",
        "prebuild": "npm run clean",
        "build": "node ../../scripts/tsc7.mjs -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "author": {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/create-azeroth"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS/tree/main/packages/create-azeroth",
    "bugs": {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
