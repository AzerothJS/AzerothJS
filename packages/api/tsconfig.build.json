{
    "extends": "../../tsconfig.json",
    "compilerOptions":
    {
        "types":
        [
            "node"
        ],
        "noEmit": false,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "rewriteRelativeImportExtensions": true,
        "paths": {}
    },
    "include":
    [
        "src/**/*"
    ],
    "exclude":
    [
        "node_modules",
        "dist"
    ]
}
