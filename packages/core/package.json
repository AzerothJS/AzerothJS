{
    "name": "@quantum/core",
    "version": "0.2.0-alpha.1",
    "description": "Quantum core — umbrella package re-exporting all Quantum APIs",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
