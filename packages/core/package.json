{
    "name": "@azerothjs/core",
    "version": "0.7.0-beta.1",
    "engines": { "node": ">=20" },
    "description": "AzerothJS core — umbrella package re-exporting all AzerothJS APIs",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports":
    {
        ".":
        {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files":
    [
        "dist"
    ],
    "sideEffects": false,
    "scripts":
    {
        "clean": "node ../../scripts/clean.mjs dist",
        "prebuild": "npm run clean",
        "build": "tsc -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "dependencies":
    {
        "@azerothjs/reactivity": "0.7.0-beta.1",
        "@azerothjs/renderer": "0.7.0-beta.1",
        "@azerothjs/component": "0.7.0-beta.1",
        "@azerothjs/server": "0.7.0-beta.1",
        "@azerothjs/store": "0.7.0-beta.1",
        "@azerothjs/form": "0.7.0-beta.1",
        "@azerothjs/router": "0.7.0-beta.1"
    },
    "publishConfig":
    {
        "access": "public"
    },
    "author":
    {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "repository":
    {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/core"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS/tree/main/packages/core",
    "bugs":
    {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
