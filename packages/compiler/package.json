{
    "name": "@azerothjs/compiler",
    "version": "0.9.0-beta.3",
    "engines": {
        "node": ">=24"
    },
    "description": "AzerothJS compiler - .azeroth single-file-component compiler (markup to h() calls) and Vite plugin",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "dependencies": {
        "@azerothjs/logger": "0.9.0-beta.3"
    },
    "peerDependencies": {
        "vite": ">=6",
        "typescript": ">=5 <7"
    },
    "peerDependenciesMeta": {
        "vite": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    "scripts": {
        "clean": "node ../../scripts/clean.mjs dist",
        "prebuild": "npm run clean",
        "build": "node ../../scripts/tsc7.mjs -p tsconfig.build.json",
        "prepublishOnly": "npm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "author": {
        "name": "IntelligentQuantum",
        "email": "IntelligentQuantum@Gmail.Com",
        "url": "https://IntelligentQuantum.Dev/"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AzerothJS/AzerothJS.git",
        "directory": "packages/compiler"
    },
    "homepage": "https://github.com/AzerothJS/AzerothJS/tree/main/packages/compiler",
    "bugs": {
        "url": "https://github.com/AzerothJS/AzerothJS/issues"
    }
}
